# GoDaddy API 配置（可选，比 RDAP 更精准）
# 免费申请: https://developer.godaddy.com/
# 复制本文件为 .env 并填入你的 Key

GODADDY_API_KEY=your_api_key_here
GODADDY_API_SECRET=your_api_secret_here

# 重要: GoDaddy 申请的第一个 Key 是 OTE 测试环境 Key
# OTE Key  → GODADDY_ENV=ote         → 使用 api.ote-godaddy.com（模拟数据）
# 生产 Key → GODADDY_ENV=production  → 使用 api.godaddy.com（真实数据）
#
# 如何获得生产 Key:
#   1. 先用 OTE Key 测试代码
#   2. 登录 https://developer.godaddy.com/keys
#   3. 点击 "Add Production Key" 申请生产 Key
GODADDY_ENV=ote
